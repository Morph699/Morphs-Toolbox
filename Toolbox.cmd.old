:CheckForUpdates
cls & echo [*] Syncing: Morph699/Morphs-Toolbox...
set "U=https://raw.githubusercontent.com/Morph699/Morphs-Toolbox/main/version.txt"
!Fetch! "!U!" -OutFile "%F_Dir%\v.txt" >nul 2>&1
if not exist "%F_Dir%\v.txt" goto :MainMenu
set /p RV=<"%F_Dir%\v.txt"
if "%RV%"=="%Version%" (timeout /t 2 >nul & goto :MainMenu)
set "U2=https://raw.githubusercontent.com/Morph699/Morphs-Toolbox/main/Toolbox.cmd"
!Fetch! "!U2!" -OutFile "%Base_Dir%T_New.cmd"
if exist "%Base_Dir%T_New.cmd" (
    (echo @echo off
    echo timeout /t 2 ^>nul
    echo del /f /q "%~f0"
    echo ren "%Base_Dir%T_New.cmd" "%~nx0"
    echo start "" "%~f0"
    echo del "%%~f0") > "%temp%\m.bat"
    start "" "%temp%\m.bat" & exit /b
)
goto :MainMenu

:GitPushUpdate
set /p msg="Commit Msg: " & git add . & git commit -m "%msg%" & git push origin main & pause & goto :MainMenu

:SaveProfile
set /p cq="IDs: " & if defined cq echo %cq% > "%F_Dir%\Profile.txt"
goto :MainMenu

:LoadProfile
if exist "%F_Dir%\Profile.txt" (set /p opts=<"%F_Dir%\Profile.txt" & goto :RunSelectionLoop)
goto :MainMenu